# ====================================
# DevOps运维管理系统环境变量配置
# ====================================
# 修改端口后执行: docker-compose down && docker-compose up -d

# ----------------
# 服务端口配置
# ----------------
# 前端访问端口(浏览器访问地址)
WEB_PORT=18088
# API后端端口
API_PORT=18000

# Prometheus监控端口
PROMETHEUS_PORT=19090

# Pushgateway推送端口
PUSHGATEWAY_PORT=19091

# ----------------
# 外网访问地址配置
# ----------------
# 图片和文件访问地址(修改为实际的IP或域名)
# 格式: http://your-ip:WEB_PORT 或 http://your-domain.com
# 示例: http://192.168.1.100:8080 或 http://devops.example.com
IMAGE_HOST=http://YOUR_SERVER_IP:18088

# ----------------
# PostgreSQL数据库配置
# ----------------
# PostgreSQL数据库端口
POSTGRES_PORT=15432
# PostgreSQL密码
POSTGRES_PASSWORD=CHANGE_ME
# 数据库名称
POSTGRES_DB=autoops
# 数据库用户
POSTGRES_USER=devops

# 数据库主机(容器环境不要改)
DB_HOST=postgres

# 数据库端口(容器内部端口,不要改)
DB_PORT=5432
# ----------------
# Valkey配置 (Redis协议兼容, BSD开源许可)
# ----------------
# Valkey缓存端口
REDIS_PORT=16379
# Valkey密码
REDIS_PASSWORD=CHANGE_ME
# Valkey地址(容器环境不要改)
REDIS_ADDR=valkey:6379
# ----------------
# 系统配置
# ----------------
# 时区配置
TZ=Asia/Shanghai
